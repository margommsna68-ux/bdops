generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// AUTH & MULTI-PROJECT
// ═══════════════════════════════════════

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  username      String?         @unique
  name          String?
  password      String?
  pin           String?
  lastActiveAt  DateTime?
  image         String?
  memberships   ProjectMember[]
  auditLogs     AuditLog[]
  proxyAssignments ProxyAssignmentHistory[] @relation("AssignedByUser")
  assignedTasks VMTask[]        @relation("TaskAssignee")
  deleteRequestsMade    DeleteRequest[] @relation("DeleteRequestor")
  deleteRequestsReviewed DeleteRequest[] @relation("DeleteReviewer")
  agentEmails      AgentPaypalEmail[] @relation("AgentEmails")
  agentWithdrawals Withdrawal[]    @relation("AgentWithdrawals")
  agentSales       AgentSale[]     @relation("AgentSales")
  resolvedDisputes Withdrawal[]    @relation("DisputeResolver")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Project {
  id               String          @id @default(cuid())
  name             String
  code             String          @unique
  description      String?
  settings         Json?
  members          ProjectMember[]
  servers          Server[]
  paypalAccounts   PayPalAccount[]
  paypalEmails     PayPalEmail[]
  fundTransactions FundTransaction[]
  withdrawals      Withdrawal[]
  costRecords      CostRecord[]
  profitSplits     ProfitSplit[]
  partners         Partner[]
  proxyIPs         ProxyIP[]
  gmailAccounts    GmailAccount[]
  deleteRequests   DeleteRequest[]
  agentPaypalEmails AgentPaypalEmail[]
  agentSales       AgentSale[]
  holderMergeTargets HolderMergeTarget[]
  earnWithdrawals  EarnWithdrawal[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ProjectMember {
  id              String      @id @default(cuid())
  user            User        @relation(fields: [userId], references: [id])
  userId          String
  project         Project     @relation(fields: [projectId], references: [id])
  projectId       String
  role            ProjectRole @default(USER)
  allowedModules  String[]    @default([])
  canManageUsers  Boolean     @default(false)
  managerId       String?
  maxAutotypeDevices Int      @default(2)
  manager         ProjectMember?  @relation("TeamMembers", fields: [managerId], references: [id])
  teamMembers     ProjectMember[] @relation("TeamMembers")
  createdAt       DateTime    @default(now())

  @@unique([userId, projectId])
}

enum ProjectRole {
  ADMIN
  MODERATOR
  USER
}

// ═══════════════════════════════════════
// INFRASTRUCTURE
// ═══════════════════════════════════════

model Server {
  id            String       @id @default(cuid())
  code          String
  ipAddress     String?
  netmask       String?
  gateway       String?
  allocation    String?
  provider      String?
  cpu           String?
  ram           String?
  status        ServerStatus @default(BUILDING)
  credentials   Json?
  inventoryId   String?
  notes         String?
  gmailGroup    Int          @default(1)
  monthlyCost   Decimal?     @db.Decimal(12, 2)
  billingCycle  Int?         @default(1) // months
  createdDate   DateTime?
  expiryDate    DateTime?
  project       Project      @relation(fields: [projectId], references: [id])
  projectId     String
  vms           VirtualMachine[]
  fundTransactions FundTransaction[]
  earnWithdrawals EarnWithdrawal[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([code, projectId])
  @@index([projectId])
}

enum ServerStatus {
  BUILDING
  ACTIVE
  SUSPENDED
  EXPIRED
  MAINTENANCE
}

model VirtualMachine {
  id            String      @id @default(cuid())
  code          String
  status        VMStatus    @default(NEW)
  sdkId         String?
  earnTotal     Decimal?    @db.Decimal(12, 4)
  earn24h       Decimal?    @db.Decimal(12, 4)
  uptime        String?
  notes         String?
  server        Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId      String
  proxy         ProxyIP?    @relation(fields: [proxyId], references: [id], onDelete: SetNull)
  proxyId       String?     @unique
  gmail         GmailAccount? @relation(fields: [gmailId], references: [id], onDelete: SetNull)
  gmailId       String?
  proxyHistory  ProxyAssignmentHistory[]
  tasks         VMTask[]
  fundTransactions FundTransaction[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([code, serverId])
}

enum VMStatus {
  NEW
  OK
  ERROR
  SUSPENDED
  NOT_CONNECTED
  NOT_AVC
  BLOCKED
}

// ═══════════════════════════════════════
// EARN APP WITHDRAWAL TRACKING
// ═══════════════════════════════════════

enum EarnWithdrawalStatus {
  PENDING
  WITHDRAWAL
  PAID
  SUSPEND
  PP_LIMIT
}

model EarnWithdrawal {
  id        String               @id @default(cuid())
  vmCodes   String               // e.g. "001-002" or "001"
  amount    Decimal?             @db.Decimal(12, 2)
  date      DateTime?
  time      String?              // "HH:MM" format
  status    EarnWithdrawalStatus @default(PENDING)
  notes     String?
  round     Int                  @default(1)
  gmail     GmailAccount         @relation(fields: [gmailId], references: [id], onDelete: Cascade)
  gmailId   String
  paypal    PayPalAccount?       @relation("EarnWithdrawalPaypal", fields: [paypalId], references: [id], onDelete: SetNull)
  paypalId  String?
  server    Server               @relation(fields: [serverId], references: [id], onDelete: Cascade)
  serverId  String
  project   Project              @relation(fields: [projectId], references: [id])
  projectId String
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([projectId, serverId])
  @@index([gmailId])
}

model ProxyIP {
  id            String      @id @default(cuid())
  address       String
  host          String?
  port          Int?
  subnet        String?
  status        ProxyStatus @default(AVAILABLE)
  outboundIP    String?
  blockReason   String?
  project       Project     @relation(fields: [projectId], references: [id])
  projectId     String
  vm            VirtualMachine?
  assignmentHistory ProxyAssignmentHistory[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([address, projectId])
  @@index([projectId, status])
}

enum ProxyStatus {
  AVAILABLE
  IN_USE
  BLOCKED
  RESERVED
}

model ProxyAssignmentHistory {
  id            String          @id @default(cuid())
  proxy         ProxyIP         @relation(fields: [proxyId], references: [id], onDelete: Cascade)
  proxyId       String
  vm            VirtualMachine  @relation(fields: [vmId], references: [id], onDelete: Cascade)
  vmId          String
  assignedAt    DateTime        @default(now())
  unassignedAt  DateTime?
  reason        String?
  assignedBy    User?           @relation("AssignedByUser", fields: [assignedById], references: [id])
  assignedById  String?
  createdAt     DateTime        @default(now())
}

// ═══════════════════════════════════════
// ACCOUNT MANAGEMENT
// ═══════════════════════════════════════

model GmailAccount {
  id            String      @id @default(cuid())
  email         String      @unique
  password      String?
  twoFaCurrent  String?
  twoFaOld      String?
  recoveryEmail String?
  token         String?
  status        GmailStatus @default(ACTIVE)
  notes         String?
  vms           VirtualMachine[]
  paypal        PayPalAccount? @relation(fields: [paypalId], references: [id], onDelete: SetNull)
  paypalId      String?
  earnWithdrawals EarnWithdrawal[]
  project       Project     @relation(fields: [projectId], references: [id])
  projectId     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([projectId])
}

enum GmailStatus {
  ACTIVE
  SUSPENDED
  NEEDS_RECOVERY
  NEEDS_2FA_UPDATE
  BLOCKED
  DISABLED
}

model PayPalAccount {
  id              String       @id @default(cuid())
  code            String
  primaryEmail    String       // denormalized from PayPalEmail for quick display/search
  secondaryEmail  String?
  password        String?      // encrypted (legacy, credentials now in PayPalEmail)
  twoFa           String?      // encrypted (legacy)
  bankCode        String?
  hotmailToken    String?      // encrypted (legacy)
  holder          String?      // who manages this PP
  vmppCode        String?      // VMPP code for PP management
  status          PayPalStatus @default(ACTIVE)
  role            PayPalRole   @default(NORMAL)
  limitNote       String?
  company         String       @default("Bright Data Ltd.")
  serverAssignment String?
  notes           String?
  holderName      String?      // Tên chủ PP
  dateOfBirth     String?      // Ngày sinh
  idNumber        String?      // Số CCCD
  address         String?      // Địa chỉ
  phone           String?      // SĐT
  docsLink        String?      // Link docs (Google Drive, etc.)
  suspendedAt     DateTime?    // Ngày bị suspend vĩnh viễn
  limitedAt       DateTime?    // Ngày bị limit (cần updocs)
  caseHistory     Json?        // [{date, type, note, docsLink}] - lịch sử xử lý
  project         Project      @relation(fields: [projectId], references: [id])
  projectId       String
  emails          PayPalEmail[]
  gmails          GmailAccount[]
  fundsReceived   FundTransaction[]
  withdrawalsFrom Withdrawal[] @relation("WithdrawalSource")
  withdrawalsTo   Withdrawal[] @relation("WithdrawalDest")
  mergeTargets    HolderMergeTarget[]
  earnWithdrawals EarnWithdrawal[] @relation("EarnWithdrawalPaypal")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([code, projectId])
  @@index([projectId, status])
  @@index([projectId, role])
}

// Holder → Mail gộp assignment (which PP is the merge target for a holder)
model HolderMergeTarget {
  id        String       @id @default(cuid())
  holder    String       // User Win (pp01, pp02...)
  paypal    PayPalAccount @relation(fields: [paypalId], references: [id], onDelete: Cascade)
  paypalId  String
  project   Project      @relation(fields: [projectId], references: [id])
  projectId String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([holder, projectId])
  @@index([projectId])
}

model PayPalEmail {
  id            String        @id @default(cuid())
  email         String
  password      String?       // encrypted
  twoFa         String?       // encrypted
  hotmailToken  String?       // encrypted
  isPrimary     Boolean       @default(false)
  notes         String?
  paypal        PayPalAccount @relation(fields: [paypalId], references: [id], onDelete: Cascade)
  paypalId      String
  project       Project       @relation(fields: [projectId], references: [id])
  projectId     String
  funds         FundTransaction[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([email, projectId])
  @@index([paypalId])
}

enum PayPalStatus {
  ACTIVE
  LIMITED
  SUSPENDED
  CLOSED
  PENDING_VERIFY
}

enum PayPalRole {
  NORMAL
  MASTER
  USDT
}

// ═══════════════════════════════════════
// FINANCIAL TRANSACTIONS
// ═══════════════════════════════════════

model FundTransaction {
  id            String        @id @default(cuid())
  date          DateTime
  amount        Decimal       @db.Decimal(12, 2)
  transactionId String
  confirmed     Boolean       @default(false)
  company       String        @default("Bright Data Ltd.")
  notes         String?
  paypal        PayPalAccount @relation(fields: [paypalId], references: [id], onDelete: Cascade)
  paypalId      String
  paypalEmail   PayPalEmail?  @relation(fields: [paypalEmailId], references: [id], onDelete: SetNull)
  paypalEmailId String?
  server        Server?       @relation(fields: [serverId], references: [id], onDelete: SetNull)
  serverId      String?
  vm            VirtualMachine? @relation(fields: [vmId], references: [id])
  vmId          String?
  project       Project       @relation(fields: [projectId], references: [id])
  projectId     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([transactionId, projectId])
  @@index([projectId, date])
  @@index([paypalId])
  @@index([paypalEmailId])
  @@index([confirmed])
  @@index([serverId])
  @@index([vmId])
}

model Withdrawal {
  id             String          @id @default(cuid())
  date           DateTime
  amount         Decimal         @db.Decimal(12, 2)
  transactionId  String?
  type           WithdrawalType
  agent          String?
  withdrawCode   String?
  ppReceived     String?
  mailConfirmed  Boolean         @default(false)
  notes          String?
  sourcePaypal   PayPalAccount   @relation("WithdrawalSource", fields: [sourcePaypalId], references: [id], onDelete: Cascade)
  sourcePaypalId String
  destPaypal     PayPalAccount?  @relation("WithdrawalDest", fields: [destPaypalId], references: [id], onDelete: SetNull)
  destPaypalId   String?
  agentUser      User?           @relation("AgentWithdrawals", fields: [agentUserId], references: [id])
  agentUserId    String?
  agentEmail     AgentPaypalEmail? @relation("AgentWithdrawalEmail", fields: [agentEmailId], references: [id])
  agentEmailId   String?
  agentConfirmed   Boolean         @default(false)
  agentDisputed    Boolean         @default(false)
  disputeNote      String?
  disputeResolved  Boolean         @default(false)
  disputeAction    String?         // "OVERRIDE" | "VOID" | "RESEND"
  adminResolveNote String?
  resolvedAt       DateTime?
  resolvedById     String?
  resolvedBy       User?           @relation("DisputeResolver", fields: [resolvedById], references: [id])
  project          Project         @relation(fields: [projectId], references: [id])
  projectId      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([projectId, date])
  @@index([projectId, type])
  @@index([sourcePaypalId])
  @@index([agentUserId])
}

enum WithdrawalType {
  MIXING
  EXCHANGE
}

model CostRecord {
  id            String    @id @default(cuid())
  code          String?
  date          DateTime
  category      String    @default("OTHER")
  amount        Decimal   @default(0) @db.Decimal(12, 2)
  serverCost    Decimal?  @db.Decimal(12, 2)
  ipCost        Decimal?  @db.Decimal(12, 2)
  extraCost     Decimal?  @db.Decimal(12, 2)
  total         Decimal   @db.Decimal(12, 2)
  isPrepaid     Boolean   @default(false)
  note          String?
  fundingSource String?
  project       Project   @relation(fields: [projectId], references: [id])
  projectId     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId, date])
}

// ═══════════════════════════════════════
// PROFIT SPLIT
// ═══════════════════════════════════════

model Partner {
  id            String      @id @default(cuid())
  name          String
  percentage    Decimal     @db.Decimal(5, 2)
  note          String?
  active        Boolean     @default(true)
  project       Project     @relation(fields: [projectId], references: [id])
  projectId     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([name, projectId])
  @@index([projectId])
}

model ProfitSplit {
  id              String            @id @default(cuid())
  periodStart     DateTime
  periodEnd       DateTime
  totalWithdrawal Decimal           @db.Decimal(14, 2)
  totalCost       Decimal           @db.Decimal(14, 2)
  netProfit       Decimal           @db.Decimal(14, 2)
  usdtRate        Decimal?          @db.Decimal(10, 4)
  netProfitUsdt   Decimal?          @db.Decimal(14, 2)
  settled         Boolean           @default(false)
  notes           String?
  project         Project           @relation(fields: [projectId], references: [id])
  projectId       String
  allocations     SplitAllocation[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model SplitAllocation {
  id            String      @id @default(cuid())
  partnerName   String
  percentage    Decimal     @db.Decimal(5, 2)
  amount        Decimal     @db.Decimal(14, 2)
  amountUsdt    Decimal?    @db.Decimal(14, 2)
  note          String?
  paid          Boolean     @default(false)
  split         ProfitSplit @relation(fields: [splitId], references: [id], onDelete: Cascade)
  splitId       String
  createdAt     DateTime    @default(now())
}

// ═══════════════════════════════════════
// VM SCHEDULED TASKS
// ═══════════════════════════════════════

model VMTask {
  id            String       @id @default(cuid())
  vm            VirtualMachine @relation(fields: [vmId], references: [id], onDelete: Cascade)
  vmId          String
  type          String
  title         String
  description   String?
  scheduledAt   DateTime
  completedAt   DateTime?
  status        VMTaskStatus @default(PENDING)
  assignedTo    User?        @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedToId  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum VMTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ═══════════════════════════════════════
// DELETE REQUESTS
// ═══════════════════════════════════════

model DeleteRequest {
  id              String              @id @default(cuid())
  entity          String
  entityId        String
  entityLabel     String?
  reason          String?
  status          DeleteRequestStatus @default(PENDING)
  requestedBy     User                @relation("DeleteRequestor", fields: [requestedById], references: [id])
  requestedById   String
  reviewedBy      User?               @relation("DeleteReviewer", fields: [reviewedById], references: [id])
  reviewedById    String?
  reviewNote      String?
  project         Project             @relation(fields: [projectId], references: [id])
  projectId       String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([projectId, status])
  @@index([entity, entityId])
}

enum DeleteRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ═══════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════

model AuditLog {
  id          String    @id @default(cuid())
  action      String
  entity      String
  entityId    String
  changes     Json?
  projectId   String?
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime  @default(now())

  @@index([entity])
  @@index([userId])
  @@index([createdAt])
  @@index([projectId])
}

// ═══════════════════════════════════════
// AGENT PAYPAL
// ═══════════════════════════════════════

model AgentPaypalEmail {
  id          String       @id @default(cuid())
  email       String
  label       String?
  user        User         @relation("AgentEmails", fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  project     Project      @relation(fields: [projectId], references: [id])
  projectId   String
  withdrawals Withdrawal[] @relation("AgentWithdrawalEmail")
  sales       AgentSale[]  @relation("AgentSaleEmail")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([email, projectId])
  @@index([userId])
  @@index([projectId])
}

model AgentSale {
  id            String           @id @default(cuid())
  amount        Decimal          @db.Decimal(12, 2)
  transactionId String
  exchangeEmail String?
  notes         String?
  agentUser     User             @relation("AgentSales", fields: [agentUserId], references: [id])
  agentUserId   String
  agentEmail    AgentPaypalEmail @relation("AgentSaleEmail", fields: [agentEmailId], references: [id])
  agentEmailId  String
  project       Project          @relation(fields: [projectId], references: [id])
  projectId     String
  date          DateTime         @default(now())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([agentUserId])
  @@index([agentEmailId])
  @@index([projectId])
}

// ═══════════════════════════════════════
// AUTOTYPE SESSIONS
// ═══════════════════════════════════════

model AutotypeSession {
  id          String   @id @default(cuid())
  userId      String
  deviceId    String   // unique device identifier from AutoType tool
  deviceName  String?  // optional label (e.g. "PC Van phong 1")
  lastActiveAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([lastActiveAt])
}
